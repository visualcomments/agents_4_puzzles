{
  "label": "real_abgolev_astar",
  "allow_failure": true,
  "state_adapter": "abgolev_stickers_12x10",
  "repo": {
    "url": "https://github.com/abgolev/A-star-Megaminx-solver.git",
    "ref": "master",
    "checkout_dir": "{repo_root}/external_real/abgolev_A-star-Megaminx-solver",
    "refresh": false,
    "allow_failure": true,
    "build_steps": [
      {
        "cmd": ["bash", "-lc", "test -f megaminx3.cpp && g++ -O3 megaminx3.cpp -o megaminx3.smoke >/dev/null 2>&1 || true"],
        "cwd": "{external_repo}",
        "timeout_seconds": 600,
        "optional": true
      }
    ]
  },
  "generator": {
    "type": "command",
    "command": [
      "python3",
      "{comp_dir}/external_solver_adapters/wrappers/run_abgolev_astar_wrapper.py",
      "--repo",
      "{external_repo}",
      "--test-csv",
      "{test_csv}",
      "--out",
      "{output_csv}",
      "--summary-out",
      "{work_dir}/real_abgolev_astar.wrapper.summary.json"
    ],
    "cwd": "{repo_root}",
    "timeout_seconds": 1200,
    "output_mode": "file",
    "output_format": "submission_csv",
    "output_path": "{output_csv}",
    "allow_failure": true
  },
  "row_key": "initial_state_id",
  "path_key": "path",
  "order": 5,
  "move_aliases": {},
  "face_aliases": {}
}
