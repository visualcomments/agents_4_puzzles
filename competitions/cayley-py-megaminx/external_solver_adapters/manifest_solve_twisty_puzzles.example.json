{
  "label": "solve_twisty_puzzles_bundle",
  "generator": {
    "type": "command",
    "command": [
      "python3",
      "{comp_dir}/external_solver_adapters/wrappers/run_solve_twisty_puzzles_wrapper.py",
      "--repo",
      "{repo_root}/external/solve-twisty-puzzles-main",
      "--test-csv",
      "{test_csv}",
      "--out",
      "{output_csv}",
      "--summary-out",
      "{work_dir}/solve_twisty_puzzles.summary.json"
    ],
    "cwd": "{repo_root}",
    "timeout_seconds": 240,
    "output_mode": "file",
    "output_format": "submission_csv",
    "output_path": "{output_csv}"
  },
  "row_key": "initial_state_id",
  "path_key": "path",
  "order": 5,
  "move_aliases": {},
  "face_aliases": {}
}
