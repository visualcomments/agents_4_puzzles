{
  "label": "real_odder_megaminxolver",
  "allow_failure": true,
  "state_adapter": "odder_last2faces",
  "repo": {
    "url": "https://github.com/Odder/MegaminXolver.git",
    "ref": "master",
    "checkout_dir": "{repo_root}/external_real/Odder_MegaminXolver",
    "refresh": false,
    "allow_failure": true,
    "build_steps": []
  },
  "generator": {
    "type": "command",
    "command": [
      "python3",
      "{comp_dir}/external_solver_adapters/wrappers/run_megaminxolver_wrapper.py",
      "--repo",
      "{external_repo}",
      "--test-csv",
      "{test_csv}",
      "--out",
      "{output_csv}",
      "--summary-out",
      "{work_dir}/real_odder_megaminxolver.wrapper.summary.json"
    ],
    "cwd": "{repo_root}",
    "timeout_seconds": 900,
    "output_mode": "file",
    "output_format": "submission_csv",
    "output_path": "{output_csv}",
    "allow_failure": true
  },
  "row_key": "initial_state_id",
  "path_key": "path",
  "order": 5,
  "move_aliases": {},
  "face_aliases": {}
}
